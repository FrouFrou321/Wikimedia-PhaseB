@model Models.Media

<form class="form" action="/Medias/@ViewBag.Action" method="POST">
    @Html.AntiForgeryToken()

    <input type="hidden" name="Id" value="@Model.Id" />
    <input type="hidden" name="OwnerId" value="@Model.OwnerId" />

    <fieldset style="border: 1px solid #ccc; border-radius: 5px; padding: 5px; margin-top: 15px;">
        <legend style="width: auto; font-size: 1rem; padding: 0 5px; margin-bottom: 0; font-weight: bold; color: #666;">
            Titre
        </legend>

        <input id="Title"
               name="Title"
               class="form-control"
               placeholder="Titre"
               value="@Model.Title"
               required
               RequireMessage="Veuillez entrer un titre" />
    </fieldset>
    <fieldset style="border: 1px solid #ccc; border-radius: 5px; padding: 10px; margin-top: 15px;">
        <legend style="width: auto; font-size: 1rem; padding: 0 10px; margin-bottom: 0; font-weight: bold; color: #666;">
            Catégorie
        </legend>

        <input type="text"
               list="Categories"
               class="form-control Alpha"
               name="Category"
               id="Category" placeholder="Catégories"
               value="@Model.Category"
               required
               RequireMessage="Veuillez entrer une catégorie"
               InvalidMessage="La catégorie comporte un caractère illégal"
               onfocusout="this.value = this.value.trim()" />
        <datalist id="Categories">
            @foreach (var category in DAL.DB.Medias.MediasCategories())
            {
                <option value="@category">@category</option>
            }
        </datalist>
    </fieldset>
    <fieldset style="border: 1px solid #ccc; border-radius: 5px; padding: 10px; margin-top: 15px;">
        <legend style="width: auto; font-size: 1rem; padding: 0 10px; margin-bottom: 0; font-weight: bold; color: #666;">
            Description
        </legend>

        <textarea class="form-control"
                  name="Description"
                  id="Description"
                  placeholder="Description"
                  style="margin-bottom:8px;"
                  rows="9"
                  required
                  RequireMessage="Veuillez entrer une Description">@Model.Description</textarea>
    </fieldset>
    <fieldset style="border: 1px solid #ccc; border-radius: 5px; padding: 10px; margin-top: 15px;">
        <legend style="width: auto; font-size: 1rem; padding: 0 10px; margin-bottom: 0; font-weight: bold; color: #666;">
            Id du media Youtube
            <i class="cmdIconSmall fa fa-info-circle" title="À propos du Id Youtube"
               onclick="bootbox.alert(
               `À propos du <b>Id Youtube</b> <hr />
        Copiez et collez l'URL du vidéo ou uniquement son id. <br /><br />
        Par exemple : <br />
        <b>https://www.youtube.com/watch?v=XYZ12345 </b><br />
        ou <br>
        <b>XYZ12345</b>`)">
    </i>
        </legend>
        <input id="YoutubeId" name="YoutubeId"
               class="form-control" placeholder="Id youtube" value="@Model.YoutubeId"
               required
               RequireMessage="Veuillez entrer un id du media Youtube"
               CustomErrorMessage="Cet id est déjà utilisé" />

        <img id="previewThumbnail" class="mediaThumbnailBig" src="https://img.youtube.com/vi/@Model.YoutubeId/mqdefault.jpg" loading="lazy">
    </fieldset>
    <fieldset style="border: 1px solid #ccc; border-radius: 5px; padding: 10px; margin-top: 15px;">
        <legend style="width: auto; font-size: 1rem; padding: 0 10px; margin-bottom: 0; font-weight: bold; color: #666;">
            Partagé
        </legend>

        <div class="form-check">
            <input type="checkbox"
                   name="Shared"
                   id="Shared"
                   class="form-check-input"
                   value="true"
                   @(Model.Shared ? "checked" : "") />
            <label class="form-check-label" for="Shared" style="cursor:pointer">
                Activé
            </label>

            <input type="hidden" name="Shared" value="false" />
        </div>
    </fieldset>

    <input id="submit" type="submit" value="Enregistrer" class="btn btn-primary" style="display:none">

    <input id="submit" type="submit" value="Enregistrer" class="btn btn-primary" style="display:none">
</form>