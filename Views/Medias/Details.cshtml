@model Models.Media
@{
    ViewBag.PageTitle = "Détails";
}

<div id="detailsPanel" class="detailsPanel">
    <!-- auto refreshed -->
</div>

@section Scripts {
    <script>
        $(() => {
            newSession(600);
            mediaDetails_ARP = new AutoRefreshedPanel("detailsPanel", "/Medias/GetMediaDetails", 5, mediaDetailsPostRefresh);
        })
        
        function mediaDetailsPostRefresh() {
            if ($("#detailsPanel").find(".not-shared-error").length > 0) {
                mediaDetails_ARP.stop();
                alert("Cette vidéo n'est plus partagée ou a été retirée.");
                window.location.href = "/Medias/Index";
            }
        }
     </script>
}